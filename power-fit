  <script>
    /* --- Sticky Nav: add 'scrolled' class after 40px --- */
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      navbar.classList.toggle('scrolled', window.scrollY > 40);
    });

    /* --- Hamburger / Mobile Menu toggle --- */
    const hamburger = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobileMenu');

    hamburger.addEventListener('click', () => {
      hamburger.classList.toggle('open');
      mobileMenu.classList.toggle('open');
    });

    // Close mobile menu on link click
    document.querySelectorAll('.mobile-link, .mobile-menu .btn').forEach(link => {
      link.addEventListener('click', () => {
        hamburger.classList.remove('open');
        mobileMenu.classList.remove('open');
      });
    });

    /* --- Scroll Reveal using IntersectionObserver --- */
    const revealEls = document.querySelectorAll('.reveal');
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });

    revealEls.forEach(el => revealObserver.observe(el));

    /* --- Contact Form Validation --- */
    const form = document.getElementById('contactForm');
    const formSuccess = document.getElementById('formSuccess');

    function validateEmail(email) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    function setError(groupId, inputEl) {
      document.getElementById(groupId).classList.add('has-error');
      inputEl.classList.add('error');
    }

    function clearError(groupId, inputEl) {
      document.getElementById(groupId).classList.remove('has-error');
      inputEl.classList.remove('error');
    }

    // Live clear on input
    ['name','email','message'].forEach(id => {
      const el = document.getElementById(id);
      const fgId = 'fg-' + id;
      if (el) el.addEventListener('input', () => clearError(fgId, el));
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      let valid = true;

      const nameEl    = document.getElementById('name');
      const emailEl   = document.getElementById('email');
      const msgEl     = document.getElementById('message');

      if (!nameEl.value.trim()) { setError('fg-name', nameEl); valid = false; }
      else clearError('fg-name', nameEl);

      if (!validateEmail(emailEl.value.trim())) { setError('fg-email', emailEl); valid = false; }
      else clearError('fg-email', emailEl);

      if (!msgEl.value.trim()) { setError('fg-message', msgEl); valid = false; }
      else clearError('fg-message', msgEl);

      if (valid) {
        // Simulate submission delay
        form.style.display = 'none';
        formSuccess.style.display = 'block';
      }
    });
  </script>

</body>
</html>
